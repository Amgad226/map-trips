generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Trip {
  id          Int       @id @default(autoincrement())
  title       String    @unique
  description String?
  latitude    Float
  longitude   Float
  tripDate    DateTime
  coverImage  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  media       Media[]
  keywords    Keyword[]
}

model Media {
  id           Int       @id @default(autoincrement())
  tripId       Int
  trip         Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  type         MediaType
  url          String
  url360p      String?
  url720p      String?
  thumbnailUrl String?
  mimeType     String
  fileSize     Int
  fileSizeBeforeCompress Int?
  order        Int       @default(0)
  isFlagged    Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([tripId])
}

model Keyword {
  id        Int      @id @default(autoincrement())
  tripId    Int
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  value     String
  createdAt DateTime @default(now())

  @@unique([tripId, value])
  @@index([tripId])
}

enum MediaType {
  IMAGE
  VIDEO
}
