generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Participant {
  id        Int               @id @default(autoincrement())
  name      String
  image     String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  trips     TripParticipant[]
}

model Trip {
  id           Int               @id @default(autoincrement())
  title        String            @unique
  description  String?
  color        String            @default("#3b82f6")
  tripDate     DateTime
  coverImage   String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  media        Media[]
  stations     Station[]
  keywords     Keyword[]
  participants TripParticipant[]
}

model TripParticipant {
  id            Int         @id @default(autoincrement())
  tripId        Int
  trip          Trip        @relation(fields: [tripId], references: [id], onDelete: Cascade)
  participantId Int
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  isBest        Boolean     @default(false)
  createdAt     DateTime    @default(now())

  @@unique([tripId, participantId])
  @@index([tripId])
  @@index([participantId])
}

model Station {
  id        Int      @id @default(autoincrement())
  name      String
  latitude  Float
  longitude Float
  order     Int      @default(0)
  tripId    Int
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  media     Media[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tripId])
}

model Media {
  id           Int       @id @default(autoincrement())
  tripId       Int
  trip         Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  stationId    Int?
  station      Station?  @relation(fields: [stationId], references: [id], onDelete: SetNull)
  type         MediaType
  url          String
  url360p      String?
  url720p      String?
  thumbnailUrl String?
  mimeType     String
  fileSize     Int
  fileSizeBeforeCompress Int?
  order        Int       @default(0)
  isFlagged    Boolean   @default(false)
  isStationCover Boolean @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([tripId])
  @@index([stationId])
}

model Keyword {
  id        Int      @id @default(autoincrement())
  tripId    Int
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  value     String
  createdAt DateTime @default(now())

  @@unique([tripId, value])
  @@index([tripId])
}

enum MediaType {
  IMAGE
  VIDEO
}
